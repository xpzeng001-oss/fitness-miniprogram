/* components/upgrade-dialog/upgrade-dialog.wxss */

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 40rpx;
}

.dialog-container {
  background: #1a1a2e;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  max-width: 600rpx;
  width: 100%;
  position: relative;
}

.close-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 32rpx;
}

.dialog-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.dialog-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.dialog-subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

.dialog-feature-list {
  margin-bottom: 32rpx;
}

.dialog-feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.dialog-feature-icon {
  font-size: 24rpx;
}

.dialog-feature-text {
  flex: 1;
  font-size: 28rpx;
  color: #cccccc;
  line-height: 1.6;
}

.dialog-pricing {
  background: rgba(255, 107, 53, 0.1);
  border: 2rpx solid rgba(255, 107, 53, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.dialog-price-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.dialog-price-label {
  font-size: 26rpx;
  color: #999999;
}

.dialog-price-value {
  display: flex;
  align-items: baseline;
}

.dialog-currency {
  font-size: 28rpx;
  color: #ff6b35;
  margin-right: 4rpx;
}

.dialog-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #ff6b35;
}

.dialog-period {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.dialog-price-tip {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  display: block;
}

.dialog-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.confirm-btn {
  background: linear-gradient(135deg, #ff6b35, #ff8c5a);
  border-radius: 48rpx;
  padding: 28rpx;
  text-align: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.cancel-btn {
  padding: 24rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.dialog-social-proof {
  text-align: center;
  font-size: 22rpx;
  color: #666666;
  display: block;
}
