/* pages/calculator/calculator.wxss */

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 计算器卡片 */
.calc-card {
  background: var(--bg-card);
}

.input-row {
  display: flex;
  gap: 16rpx;
}

.input-lg {
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  min-height: 88rpx;
}

/* 选择器按钮 */
.picker-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 24rpx;
}

.picker-value {
  color: var(--text-primary);
  font-size: 30rpx;
}

.picker-arrow {
  color: var(--text-muted);
  font-size: 24rpx;
}

/* 结果卡片 */
.result-card {
  background: var(--bg-card);
  text-align: center;
}

.result-header {
  padding: 20rpx 0;
}

.result-label {
  font-size: 26rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 12rpx;
}

.result-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.result-value {
  font-size: 96rpx;
  font-weight: 800;
  color: var(--primary-color);
  line-height: 1;
}

.result-unit {
  font-size: 36rpx;
  color: var(--text-muted);
  margin-left: 12rpx;
}

.result-formula {
  font-size: 24rpx;
  color: var(--text-muted);
}

.save-pr-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.save-pr-hint {
  font-size: 28rpx;
  color: var(--warning);
  display: block;
  margin-bottom: 16rpx;
}

.pr-saved {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.pr-saved-text {
  color: var(--success);
  font-size: 28rpx;
  font-weight: 600;
}

/* 推荐卡片 */
.recommend-card {
  background: var(--bg-card);
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recommend-item {
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.recommend-item.strength {
  border-color: rgba(255, 107, 53, 0.3);
}

.recommend-item.hypertrophy {
  border-color: rgba(0, 212, 170, 0.3);
}

.recommend-item.endurance {
  border-color: rgba(255, 193, 7, 0.3);
}

.recommend-item.warmup {
  border-color: rgba(164, 167, 174, 0.3);
}

.recommend-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.recommend-icon {
  font-size: 28rpx;
}

.recommend-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.recommend-percent {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.recommend-weight {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 8rpx;
}

.recommend-weight .weight-value {
  font-size: 40rpx;
  font-weight: 700;
}

.recommend-item.strength .weight-value { color: var(--primary-color); }
.recommend-item.hypertrophy .weight-value { color: var(--success); }
.recommend-item.endurance .weight-value { color: var(--warning); }
.recommend-item.warmup .weight-value { color: var(--text-secondary); }

.recommend-weight .weight-unit {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

.recommend-reps {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 百分比表格 */
.percent-table {
  border-radius: var(--border-radius);
  overflow: hidden;
}

.percent-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.percent-row:last-child {
  border-bottom: none;
}

.percent-row.header {
  background: var(--bg-card-light);
  font-weight: 600;
  color: var(--text-secondary);
}

.percent-col {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.percent-col.weight {
  font-weight: 600;
  color: var(--primary-color);
}

.percent-col.reps {
  color: var(--success);
}

/* 公式说明 */
.info-card {
  background: var(--bg-card);
}

.formula-section {
  margin-bottom: 24rpx;
}

.formula-item {
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.formula-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
  display: block;
  margin-bottom: 8rpx;
}

.formula-math {
  font-size: 26rpx;
  font-family: 'Courier New', monospace;
  color: var(--text-primary);
  background: rgba(0, 0, 0, 0.3);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  display: block;
  margin-bottom: 12rpx;
}

.formula-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.tips-section {
  background: rgba(255, 193, 7, 0.1);
  border-radius: var(--border-radius);
  padding: 20rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--warning);
  margin-bottom: 12rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.tip-icon {
  color: var(--warning);
  margin-right: 12rpx;
  font-size: 24rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}
