.exercise-page {
  min-height: 100vh;
  background: var(--bg-dark);
  padding: 40rpx;
  padding-bottom: calc(126rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.library-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 36rpx;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.library-title {
  color: var(--text-primary);
  font-size: 56rpx;
  line-height: 1;
  font-weight: 800;
}

.search-button {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.search-glass {
  width: 26rpx;
  height: 26rpx;
  border: 6rpx solid var(--text-primary);
  border-radius: 50%;
  position: relative;
}

.search-glass::after {
  content: "";
  position: absolute;
  width: 17rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--text-primary);
  right: -14rpx;
  bottom: -7rpx;
  transform: rotate(45deg);
}

.search-panel {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 24rpx;
}

.search-input {
  height: 72rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

.library-content {
  display: flex;
  gap: 32rpx;
  align-items: flex-start;
}

.muscle-sidebar {
  width: 240rpx;
  flex-shrink: 0;
  max-height: calc(100vh - 220rpx);
}

.sidebar-label,
.section-label {
  display: block;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.muscle-panel {
  background: rgba(30, 31, 35, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 24rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.muscle-panel.expanded {
  background: var(--bg-card);
}

.muscle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.muscle-name {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.muscle-count {
  display: block;
  color: var(--text-muted);
  font-size: 22rpx;
  margin-top: 6rpx;
}

.muscle-chevron {
  color: var(--text-muted);
  font-size: 28rpx;
  font-weight: 700;
}

.sub-muscle-list {
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.sub-muscle {
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  gap: 12rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sub-muscle.active {
  background: var(--bg-card-light);
  color: var(--text-primary);
  border-color: rgba(255, 255, 255, 0.08);
}

.sub-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.sub-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 700;
}

.sub-count {
  font-size: 22rpx;
  font-weight: 700;
}

.exercise-main {
  flex: 1;
  min-width: 0;
  max-height: calc(100vh - 220rpx);
}

.equipment-scroll {
  white-space: nowrap;
  margin-bottom: 34rpx;
}

.equipment-tabs {
  display: flex;
  gap: 18rpx;
}

.equipment-tab {
  flex-shrink: 0;
  min-width: 118rpx;
  height: 62rpx;
  padding: 0 30rpx;
  border-radius: 34rpx;
  background: var(--bg-card);
  color: var(--text-muted);
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.equipment-tab.active {
  color: var(--text-primary);
  background: var(--bg-card-light);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.exercise-section {
  margin-bottom: 34rpx;
}

.equipment-title {
  display: block;
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 20rpx;
}

.movement-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.movement-card.locked {
  opacity: 0.62;
}

.movement-thumb {
  width: 150rpx;
  height: 130rpx;
  border-radius: 22rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.movement-figure {
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  background: #111216;
  color: #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  transform: rotate(-12deg);
}

.movement-image {
  width: 100%;
  height: 100%;
  display: block;
}

.movement-info {
  flex: 1;
  min-width: 0;
}

.movement-name {
  display: block;
  color: var(--text-primary);
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.movement-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.movement-tag {
  color: var(--text-muted);
  background: rgba(255, 255, 255, 0.04);
  border-radius: 22rpx;
  padding: 7rpx 18rpx;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 700;
}

.movement-tag.primary {
  color: var(--text-secondary);
  background: var(--bg-card-light);
}

.lock-badge {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  color: #141519;
  background: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
  font-weight: 800;
}

.empty-library {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 60rpx 32rpx;
}

.empty-title,
.empty-desc {
  display: block;
  text-align: center;
}

.empty-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  color: var(--text-muted);
  font-size: 24rpx;
  margin-top: 12rpx;
}
