/* pages/index/index.wxss */

/* 头部区域 */
.header {
  margin-bottom: 40rpx;
}

.greeting {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ffffff 0%, #a0a0b0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.greeting-emoji {
  font-size: 44rpx;
  margin-left: 16rpx;
  animation: pulse 2s ease-in-out infinite;
}

.date-display {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(145deg, var(--bg-card) 0%, var(--bg-card-light) 100%);
  border: 1rpx solid rgba(255, 107, 53, 0.2);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.streak-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 107, 53, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.streak-fire {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.streak-text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, var(--text-muted), transparent);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 30rpx 20rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.action-btn:active {
  transform: scale(0.95);
  background: var(--bg-card-light);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* PR记录列表 */
.pr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.pr-item:last-child {
  border-bottom: none;
}

.pr-info {
  flex: 1;
}

.pr-exercise {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.pr-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.pr-weight {
  display: flex;
  align-items: baseline;
}

.pr-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.pr-unit {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
}

/* 体重预览 */
.weight-preview {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 30rpx;
}

.weight-current {
  display: flex;
  align-items: baseline;
}

.weight-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.weight-unit {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
}

.weight-change {
  display: flex;
  flex-direction: column;
  padding: 12rpx 20rpx;
  border-radius: var(--border-radius);
  font-size: 28rpx;
  font-weight: 600;
}

.weight-change.decrease {
  background: rgba(0, 212, 170, 0.15);
  color: var(--success);
}

.weight-change.increase {
  background: rgba(255, 71, 87, 0.15);
  color: var(--danger);
}

.weight-period {
  font-size: 22rpx;
  opacity: 0.7;
  font-weight: 400;
}

/* 迷你图表 */
.mini-chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 80rpx;
  flex: 1;
  min-width: 200rpx;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 10rpx;
  transition: height 0.5s ease;
}

/* 打卡卡片 */
.checkin-card {
  background: linear-gradient(145deg, var(--bg-card) 0%, rgba(0, 212, 170, 0.1) 100%);
}

.checkin-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkin-info {
  flex: 1;
}

.checkin-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.checkin-status {
  font-size: 26rpx;
  color: var(--text-muted);
}

.checkin-status.done {
  color: var(--success);
  font-weight: 600;
}

/* 空状态优化 */
.empty-state {
  padding: 40rpx 20rpx;
}
