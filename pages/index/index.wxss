/* pages/index/index.wxss */

/* 头部区域 */
.header {
  margin-bottom: 40rpx;
}

.greeting {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ffffff 0%, #a4a7ae 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.greeting-emoji {
  font-size: 44rpx;
  margin-left: 16rpx;
  animation: pulse 2s ease-in-out infinite;
}

.date-display {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 统计卡片 */
.stats-card {
  background: var(--bg-card);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.streak-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 107, 53, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.streak-fire {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.streak-text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, var(--text-muted), transparent);
}

/* PR记录列表 */
.pr-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.pr-item:last-child {
  border-bottom: none;
}

.pr-info {
  flex: 1;
}

.pr-exercise {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.pr-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.pr-weight {
  display: flex;
  align-items: baseline;
}

.pr-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.pr-unit {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
}

/* 体重预览 */
.weight-preview {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 30rpx;
}

.weight-current {
  display: flex;
  align-items: baseline;
}

.weight-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.weight-unit {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
}

.weight-change {
  display: flex;
  flex-direction: column;
  padding: 12rpx 20rpx;
  border-radius: var(--border-radius);
  font-size: 28rpx;
  font-weight: 600;
}

.weight-change.decrease {
  background: rgba(0, 212, 170, 0.15);
  color: var(--success);
}

.weight-change.increase {
  background: rgba(255, 71, 87, 0.15);
  color: var(--danger);
}

.weight-period {
  font-size: 22rpx;
  opacity: 0.7;
  font-weight: 400;
}

/* 迷你图表 */
.mini-chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 80rpx;
  flex: 1;
  min-width: 200rpx;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 10rpx;
  transition: height 0.5s ease;
}

/* 打卡卡片 */
.checkin-card {
  background: var(--bg-card);
}

.checkin-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkin-info {
  flex: 1;
}

.checkin-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.checkin-status {
  font-size: 26rpx;
  color: var(--text-muted);
}

.checkin-status.done {
  color: var(--primary-color);
  font-weight: 600;
}

/* 空状态优化 */
.empty-state {
  padding: 40rpx 20rpx;
}

/* 训练表单 */
.form-card {
  background: var(--bg-card);
}

.input-row {
  display: flex;
  gap: 16rpx;
}

.picker-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 24rpx;
}

.picker-value {
  color: var(--text-primary);
  font-size: 30rpx;
}

.picker-arrow {
  color: var(--text-muted);
  font-size: 24rpx;
}

.pr-hint {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.2) 0%, rgba(255, 193, 7, 0.2) 100%);
  border-radius: var(--border-radius);
  padding: 20rpx;
  margin-top: 24rpx;
}

.pr-hint-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.pr-hint-text {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.record-count {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 400;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-main {
  flex: 1;
}

.record-exercise {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.exercise-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.exercise-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.pr-badge {
  background: var(--primary-color);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.record-detail {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-weight {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.detail-reps,
.detail-sets {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-sep {
  color: var(--text-muted);
  font-size: 24rpx;
}

.record-volume {
  text-align: right;
  margin-right: 30rpx;
}

.volume-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
  display: block;
}

.volume-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.record-delete {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 32rpx;
  opacity: 0.6;
}

.record-delete:active {
  color: var(--danger);
  opacity: 1;
}

/* 训练打卡日历 */
.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkin-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-streak {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.checkin-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkin-btn {
  background: var(--primary-color);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.checkin-btn.checked {
  background: var(--bg-card-light);
  color: var(--primary-color);
  border: 2rpx solid rgba(255, 107, 53, 0.55);
}

.expand-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  transition: transform 0.3s;
}

.expand-arrow.expanded {
  transform: rotate(180deg);
}

.checkin-calendar {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.checkin-calendar.show {
  max-height: 800rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-btn {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 8rpx 16rpx;
}

.calendar-month {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 12rpx;
}

.weekday {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 8rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.calendar-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 12rpx;
  position: relative;
}

.calendar-day.other-month .day-text {
  color: var(--text-muted);
  opacity: 0.3;
}

.calendar-day.today {
  background: rgba(255, 107, 53, 0.15);
}

.calendar-day.today .day-text {
  color: var(--primary-color);
  font-weight: 700;
}

.calendar-day.checkin-day {
  background: rgba(255, 107, 53, 0.13);
}

.calendar-day.checkin-day .day-text {
  color: var(--primary-color);
  font-weight: 600;
}

.calendar-day.today.checkin-day {
  background: rgba(255, 107, 53, 0.2);
}

.day-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.checkin-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--primary-color);
  position: absolute;
  bottom: 6rpx;
}

.calendar-summary {
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.summary-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
