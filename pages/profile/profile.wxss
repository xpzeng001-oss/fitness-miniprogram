/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 1. 用户卡片 */
.user-card {
  background: linear-gradient(135deg, var(--bg-card) 0%, rgba(255, 107, 53, 0.1) 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid var(--primary-color);
  background: var(--bg-card-light);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.avatar-edit-icon {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon-text {
  font-size: 20rpx;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.nickname-edit {
  font-size: 28rpx;
  color: var(--text-muted);
}

.stats-brief {
  display: flex;
  gap: 20rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.streak {
  color: var(--primary-color);
  font-weight: 500;
}

/* 2. 数据统计区 */
.stats-section {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: var(--bg-card-light);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 3. 成就墙 */
.achievements-section {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.achievement-count {
  color: var(--text-muted);
  font-size: 24rpx;
}

.achievement-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.achievement-progress .progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--bg-card-light);
  border-radius: 6rpx;
  overflow: hidden;
}

.achievement-progress .progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 6rpx;
}

.progress-text {
  color: var(--primary-color);
  font-size: 24rpx;
  font-weight: 600;
  min-width: 60rpx;
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.achievement-card {
  background: var(--bg-card-light);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  position: relative;
}

.achievement-card.unlocked {
  background: rgba(255, 107, 53, 0.1);
  border: 2rpx solid rgba(255, 107, 53, 0.3);
}

.achievement-card.locked {
  opacity: 0.5;
}

.achievement-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}

.achievement-title {
  font-size: 24rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
  font-weight: 500;
}

.achievement-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
}

.unlock-date {
  font-size: 18rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

/* 4. 设置区 */
.settings-section {
  margin-bottom: 24rpx;
}

.setting-group {
  background: var(--bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger {
  background: rgba(255, 71, 87, 0.05);
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.setting-label.danger-text {
  color: var(--danger);
}

.setting-value {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-right: 12rpx;
}

.arrow {
  color: var(--text-muted);
  font-size: 32rpx;
}

.data-summary {
  padding: 24rpx 32rpx;
}

.summary-item {
  display: block;
  color: var(--text-muted);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

/* 5. 关于 */
.about-section {
  margin-bottom: 24rpx;
}
