/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background: var(--bg-dark);
  padding: 40rpx;
  padding-bottom: calc(126rpx + env(safe-area-inset-bottom));
}

/* 1. 用户卡片 */
.user-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid var(--primary-color);
  background: var(--bg-card-light);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.avatar-edit-icon {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-icon-text {
  font-size: 20rpx;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.nickname-edit {
  font-size: 28rpx;
  color: var(--text-muted);
}

.stats-brief {
  display: flex;
  gap: 20rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.streak {
  color: var(--primary-color);
  font-weight: 500;
}

/* 2. 数据统计区 */
.stats-section {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 3. 成就墙 */
.achievements-section {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 42rpx 40rpx 40rpx;
  margin-bottom: 32rpx;
}

.achievements-summary {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  margin-bottom: 34rpx;
}

.achievement-mark {
  width: 38rpx;
  height: 38rpx;
  margin-top: 4rpx;
  border: 4rpx solid var(--text-primary);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.achievement-mark-text {
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.achievement-main {
  flex: 1;
  min-width: 0;
}

.achievement-heading {
  display: block;
  color: var(--text-primary);
  font-size: 42rpx;
  line-height: 1.15;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.achievement-count {
  color: var(--text-muted);
  display: block;
  font-size: 28rpx;
  line-height: 1.2;
}

.achievement-toggle {
  min-width: 130rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.toggle-chevron {
  width: 18rpx;
  height: 18rpx;
  border-right: 5rpx solid var(--text-primary);
  border-bottom: 5rpx solid var(--text-primary);
  transform: rotate(45deg);
  margin-top: -6rpx;
}

.toggle-chevron.expanded {
  transform: rotate(225deg);
  margin-top: 6rpx;
}

.achievement-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 0;
}

.achievement-progress .progress-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.achievement-progress .progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.achievement-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  position: relative;
}

.achievement-card.unlocked {
  border: 2rpx solid rgba(255, 107, 53, 0.3);
}

.achievement-card.locked {
  opacity: 0.5;
}

.achievement-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}

.achievement-title {
  font-size: 24rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
  font-weight: 500;
}

.achievement-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
}

.unlock-date {
  font-size: 18rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

/* 4. 工具入口 */
.tools-entry {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.tools-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: var(--bg-card-light);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  padding: 18rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.tools-dot {
  background: var(--text-primary);
  border-radius: 8rpx;
}

.tools-main {
  flex: 1;
  min-width: 0;
}

.tools-title {
  display: block;
  color: var(--text-primary);
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.tools-desc {
  display: block;
  color: var(--text-muted);
  font-size: 26rpx;
  line-height: 1.25;
}

.tools-arrow {
  color: var(--text-muted);
  font-size: 52rpx;
  line-height: 1;
}

/* 5. 设置区 */
.settings-section {
  margin-bottom: 32rpx;
}

.setting-group {
  background: var(--bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item.danger {
  background: rgba(255, 71, 87, 0.05);
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.setting-label.danger-text {
  color: var(--danger);
}

.setting-value {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-right: 12rpx;
}

.arrow {
  color: var(--text-muted);
  font-size: 32rpx;
}

.data-summary {
  padding: 24rpx 32rpx;
}

.summary-item {
  display: block;
  color: var(--text-muted);
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

/* 6. 关于 */
.about-section {
  margin-bottom: 32rpx;
}
