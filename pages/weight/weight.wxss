/* pages/weight/weight.wxss */

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 打卡卡片 */
.checkin-card {
  background: linear-gradient(145deg, var(--bg-card) 0%, rgba(0, 212, 170, 0.1) 100%);
  border: 2rpx solid rgba(0, 212, 170, 0.2);
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.checkin-info {
  flex: 1;
}

.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.streak-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.streak-fire {
  font-size: 28rpx;
}

.streak-count {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.checkin-status {
  font-size: 26rpx;
  color: var(--text-muted);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: var(--bg-card-light);
}

.checkin-status.done {
  color: var(--success);
  background: rgba(0, 212, 170, 0.2);
}

/* 体重输入 */
.weight-input-section {
  margin-top: 20rpx;
}

.weight-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weight-adjust {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card-light);
  border-radius: 50%;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.weight-adjust:active {
  background: var(--primary-color);
  color: white;
}

.weight-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: 700;
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  min-height: 88rpx;
}

/* 已记录显示 */
.today-recorded {
  text-align: center;
  padding: 20rpx 0;
}

.recorded-weight {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.recorded-value {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--success);
}

.recorded-unit {
  font-size: 32rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
}

.recorded-time {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.cancel-checkin {
  margin-top: 20rpx;
}

.cancel-checkin-text {
  font-size: 24rpx;
  color: var(--text-muted);
  text-decoration: underline;
}

/* 概览统计 */
.stats-overview {
  background: var(--bg-card);
}

.overview-grid {
  display: flex;
  align-items: center;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.overview-value-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.overview-value.decrease {
  color: var(--success);
}

.overview-value.increase {
  color: var(--danger);
}

.overview-unit {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, var(--text-muted), transparent);
}

/* 图表卡片 */
.chart-card {
  background: var(--bg-card);
}

.chart-period-selector {
  display: flex;
  gap: 8rpx;
  margin-left: auto;
}

.period-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  background: var(--bg-card-light);
  border-radius: 16rpx;
  transition: all 0.2s;
}

.period-btn.active {
  background: var(--primary-color);
  color: white;
}

/* 图表容器 */
.chart-container {
  display: flex;
  height: 350rpx;
  margin-top: 24rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 10rpx 0;
}

.y-label {
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: right;
}

.chart-main {
  flex: 1;
  position: relative;
  margin-left: 16rpx;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 10rpx 0;
}

.grid-line {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.chart-data {
  position: absolute;
  top: 10rpx;
  left: 0;
  right: 0;
  bottom: 10rpx;
}

.chart-line-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.chart-path {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255, 107, 53, 0.3) 0%, transparent 100%);
  clip-path: var(--clip-path);
}

.data-point {
  position: absolute;
  transform: translate(-50%, 50%);
  z-index: 10;
}

.point-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary-color);
  border-radius: 50%;
  border: 4rpx solid var(--bg-card);
  box-shadow: 0 0 10rpx rgba(255, 107, 53, 0.5);
}

.point-tooltip {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-card-light);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s;
  z-index: 20;
}

.point-tooltip.show {
  opacity: 1;
  visibility: visible;
}

.tooltip-weight {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  display: block;
}

.tooltip-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 周期统计 */
.period-stats {
  background: var(--bg-card);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-box {
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 20rpx;
  text-align: center;
}

.stat-box-label {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.stat-box-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-box-value.decrease {
  color: var(--success);
}

.stat-box-value.increase {
  color: var(--danger);
}

/* 历史记录 */
.history-card {
  background: var(--bg-card);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.history-item:last-child {
  border-bottom: none;
}

.history-date {
  width: 80rpx;
  text-align: center;
}

.date-day {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.date-month {
  font-size: 22rpx;
  color: var(--text-muted);
}

.history-info {
  flex: 1;
  margin-left: 24rpx;
}

.history-weight {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.history-weekday {
  font-size: 24rpx;
  color: var(--text-muted);
}

.history-change {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-muted);
  margin-right: 20rpx;
}

.history-change.decrease {
  color: var(--success);
}

.history-change.increase {
  color: var(--danger);
}

.history-delete {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 32rpx;
  opacity: 0.6;
}

.history-delete:active {
  color: var(--danger);
  opacity: 1;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: var(--primary-color);
  font-size: 26rpx;
}

/* 目标设置 */
.goal-card {
  background: linear-gradient(145deg, var(--bg-card) 0%, rgba(255, 107, 53, 0.05) 100%);
}

.goal-content {
  margin-top: 16rpx;
}

.goal-display {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goal-progress {
  width: 100%;
}

.progress-bar {
  height: 16rpx;
  background: var(--bg-card-light);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--success) 0%, var(--primary-color) 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-muted);
}

.goal-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goal-remaining {
  display: flex;
  flex-direction: column;
}

.remaining-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.remaining-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}
