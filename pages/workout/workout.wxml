<!--pages/workout/workout.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header animate-fade-in">
    <text class="page-title">{{greeting}}</text>
    <text class="page-subtitle">{{currentDate}}</text>
  </view>

  <!-- 打卡区域 -->
  <view class="card checkin-card animate-slide-up">
    <view class="checkin-header" bindtap="toggleCheckinCalendar">
      <view class="checkin-left">
        <text class="card-title-icon">📅</text>
        <text class="checkin-title">训练打卡</text>
        <text class="checkin-streak" wx:if="{{checkinStreak > 0}}">🔥 连续{{checkinStreak}}天</text>
      </view>
      <view class="checkin-right">
        <view class="checkin-btn {{todayCheckedIn ? 'checked' : ''}}" catchtap="doCheckin">
          <text>{{todayCheckedIn ? '✓ 已打卡' : '打卡'}}</text>
        </view>
        <text class="expand-arrow {{showCalendar ? 'expanded' : ''}}">▼</text>
      </view>
    </view>

    <!-- 展开的打卡日历 -->
    <view class="checkin-calendar {{showCalendar ? 'show' : ''}}">
      <view class="calendar-nav">
        <text class="nav-btn" bindtap="prevMonth">◀</text>
        <text class="calendar-month">{{calendarYear}}年{{calendarMonth}}月</text>
        <text class="nav-btn" bindtap="nextMonth">▶</text>
      </view>
      <view class="calendar-weekdays">
        <text class="weekday">日</text>
        <text class="weekday">一</text>
        <text class="weekday">二</text>
        <text class="weekday">三</text>
        <text class="weekday">四</text>
        <text class="weekday">五</text>
        <text class="weekday">六</text>
      </view>
      <view class="calendar-days">
        <view
          wx:for="{{calendarDays}}"
          wx:key="index"
          class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.hasCheckin ? 'checkin-day' : ''}}"
        >
          <text class="day-text">{{item.day}}</text>
          <view wx:if="{{item.hasCheckin}}" class="checkin-dot"></view>
        </view>
      </view>
      <view class="calendar-summary">
        <text class="summary-text">本月打卡 {{monthCheckinCount}} 天</text>
      </view>
    </view>
  </view>

  <!-- 添加训练记录表单 -->
  <view class="card form-card animate-slide-up">
    <view class="card-title">
      <text class="card-title-icon">➕</text>
      <text>添加记录</text>
    </view>

    <!-- 动作选择 -->
    <view class="input-group">
      <text class="input-label">选择动作</text>
      <picker bindchange="onExerciseChange" value="{{exerciseIndex}}" range="{{exerciseNames}}">
        <view class="picker-btn">
          <text class="picker-value">{{selectedExercise || '请选择训练动作'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 重量输入 -->
    <view class="input-row">
      <view class="input-group flex-1">
        <text class="input-label">重量 (kg)</text>
        <input class="input" type="digit" placeholder="输入重量"
               style="color:#ffffff;"
               placeholder-style="color:#777b84;"
               value="{{weight}}" bindinput="onWeightInput"/>
      </view>

      <view class="input-group flex-1 ml-20">
        <text class="input-label">次数</text>
        <input class="input" type="number" placeholder="输入次数"
               style="color:#ffffff;"
               placeholder-style="color:#777b84;"
               value="{{reps}}" bindinput="onRepsInput"/>
      </view>

      <view class="input-group flex-1 ml-20">
        <text class="input-label">组数</text>
        <input class="input" type="number" placeholder="输入组数"
               style="color:#ffffff;"
               placeholder-style="color:#777b84;"
               value="{{sets}}" bindinput="onSetsInput"/>
      </view>
    </view>

    <!-- PR 提示 -->
    <view class="pr-hint" wx:if="{{isPR}}">
      <text class="pr-hint-icon">🎉</text>
      <text class="pr-hint-text">新PR！超越了之前的 {{currentPR}}kg</text>
    </view>

    <!-- 添加按钮 -->
    <button class="btn btn-primary btn-block mt-30" bindtap="addRecord">
      <text>记录训练</text>
    </button>
  </view>

  <!-- 今日训练记录 -->
  <view class="card animate-slide-up" style="animation-delay: 0.1s;">
    <view class="card-title">
      <text class="card-title-icon">📋</text>
      <text>今日记录</text>
      <text class="record-count">{{todayRecords.length}}组</text>
    </view>

    <view wx:if="{{todayRecords.length > 0}}">
      <view class="record-item" wx:for="{{todayRecords}}" wx:key="index">
        <view class="record-main">
          <view class="record-exercise">
            <text class="exercise-icon">{{item.icon}}</text>
            <text class="exercise-name">{{item.exercise}}</text>
            <view class="pr-badge" wx:if="{{item.isPR}}">PR</view>
          </view>
          <view class="record-detail">
            <text class="detail-weight">{{item.weight}}kg</text>
            <text class="detail-sep">×</text>
            <text class="detail-reps">{{item.reps}}次</text>
            <text class="detail-sep">×</text>
            <text class="detail-sets">{{item.sets}}组</text>
          </view>
        </view>
        <view class="record-volume">
          <text class="volume-value">{{item.volume}}</text>
          <text class="volume-label">容量</text>
        </view>
        <view class="record-delete" bindtap="deleteRecord" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">🏃</text>
      <text class="empty-text">今天还没有训练记录</text>
    </view>
  </view>

  <!-- PR 记录榜 -->
  <view class="card animate-slide-up" style="animation-delay: 0.2s;">
    <view class="card-title">
      <text class="card-title-icon">🏆</text>
      <text>个人记录 (PR)</text>
    </view>

    <view wx:if="{{prList.length > 0}}">
      <view class="pr-list-item" wx:for="{{prList}}" wx:key="exercise">
        <view class="pr-list-info">
          <text class="pr-list-exercise">{{item.exercise}}</text>
          <text class="pr-list-date">{{item.date}}</text>
        </view>
        <view class="pr-list-weight">
          <text class="pr-list-value">{{item.weight}}</text>
          <text class="pr-list-unit">kg</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">🎯</text>
      <text class="empty-text">开始训练，创造你的PR！</text>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="card animate-slide-up" style="animation-delay: 0.3s;">
    <view class="card-title flex justify-between items-center">
      <view class="flex items-center">
        <text class="card-title-icon">📅</text>
        <text>历史记录</text>
      </view>
      <view class="history-filter" bindtap="toggleFilter">
        <text>{{selectedFilter}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </view>

    <view wx:if="{{historyRecords.length > 0}}">
      <view class="history-group" wx:for="{{historyRecords}}" wx:key="date">
        <view class="history-date">{{item.date}}</view>
        <view class="history-item" wx:for="{{item.records}}" wx:for-item="rec" wx:key="index">
          <text class="history-exercise">{{rec.exercise}}</text>
          <text class="history-detail">{{rec.weight}}kg × {{rec.reps}} × {{rec.sets}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无历史记录</text>
    </view>
  </view>
</view>

<!-- 筛选弹窗 -->
<view class="filter-popup {{showFilter ? 'show' : ''}}" bindtap="hideFilter">
  <view class="filter-content" catchtap="">
    <view class="filter-title">筛选动作</view>
    <view class="filter-options">
      <view class="filter-option {{selectedFilter === '全部' ? 'active' : ''}}" 
            bindtap="selectFilter" data-filter="全部">全部</view>
      <view class="filter-option {{selectedFilter === item ? 'active' : ''}}" 
            wx:for="{{exerciseNames}}" wx:key="index"
            bindtap="selectFilter" data-filter="{{item}}">{{item}}</view>
    </view>
  </view>
</view>
