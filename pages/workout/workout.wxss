/* pages/workout/workout.wxss */

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 表单卡片 */
.form-card {
  background: var(--bg-card);
}

.input-row {
  display: flex;
  gap: 16rpx;
}

/* 选择器按钮 */
.picker-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  padding: 24rpx;
}

.picker-value {
  color: var(--text-primary);
  font-size: 30rpx;
}

.picker-arrow {
  color: var(--text-muted);
  font-size: 24rpx;
}

/* 快速调整重量 */
.quick-weight {
  margin-top: 24rpx;
}

.weight-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.weight-btn {
  flex: 1;
  background: var(--bg-card-light);
  border: 2rpx solid var(--text-muted);
  border-radius: var(--border-radius);
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.weight-btn:active {
  background: var(--primary-color);
  border-color: var(--primary-color);
  color: white;
}

/* PR 提示 */
.pr-hint {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.2) 0%, rgba(255, 193, 7, 0.2) 100%);
  border-radius: var(--border-radius);
  padding: 20rpx;
  margin-top: 24rpx;
}

.pr-hint-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.pr-hint-text {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* 记录计数 */
.record-count {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 400;
}

/* 训练记录项 */
.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-main {
  flex: 1;
}

.record-exercise {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.exercise-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.exercise-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.pr-badge {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--warning) 100%);
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.record-detail {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-weight {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.detail-reps, .detail-sets {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-sep {
  color: var(--text-muted);
  font-size: 24rpx;
}

.record-volume {
  text-align: right;
  margin-right: 30rpx;
}

.volume-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--success);
  display: block;
}

.volume-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.record-delete {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 32rpx;
  opacity: 0.6;
}

.record-delete:active {
  color: var(--danger);
  opacity: 1;
}

/* PR列表 */
.pr-list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.pr-list-item:last-child {
  border-bottom: none;
}

.pr-list-info {
  flex: 1;
}

.pr-list-exercise {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.pr-list-date {
  font-size: 24rpx;
  color: var(--text-muted);
}

.pr-list-weight {
  display: flex;
  align-items: baseline;
  margin-right: 30rpx;
}

.pr-list-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.pr-list-unit {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 4rpx;
}

.pr-list-1rm {
  text-align: right;
  background: rgba(0, 212, 170, 0.1);
  padding: 12rpx 16rpx;
  border-radius: var(--border-radius);
}

.pr-1rm-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
}

.pr-1rm-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--success);
}

/* 历史记录 */
.history-filter {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-card-light);
  padding: 12rpx 20rpx;
  border-radius: var(--border-radius);
}

.history-group {
  margin-bottom: 24rpx;
}

.history-date {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid rgba(255, 107, 53, 0.3);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.history-exercise {
  font-size: 28rpx;
  color: var(--text-primary);
}

.history-detail {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 筛选弹窗 */
.filter-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 1000;
}

.filter-popup.show {
  opacity: 1;
  visibility: visible;
}

.filter-content {
  width: 100%;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  max-height: 70vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.filter-popup.show .filter-content {
  transform: translateY(0);
}

.filter-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 30rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 20rpx 32rpx;
  background: var(--bg-card-light);
  border-radius: var(--border-radius);
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.filter-option.active {
  background: var(--primary-color);
  color: white;
}

/* 打卡卡片 */
.checkin-card {
  background: var(--bg-card);
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkin-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.checkin-streak {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.checkin-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkin-btn {
  background: linear-gradient(135deg, var(--success), #00b894);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.checkin-btn.checked {
  background: var(--bg-card-light);
  color: var(--success);
  border: 2rpx solid var(--success);
}

.expand-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  transition: transform 0.3s;
}

.expand-arrow.expanded {
  transform: rotate(180deg);
}

/* 日历 */
.checkin-calendar {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.checkin-calendar.show {
  max-height: 800rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-btn {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 8rpx 16rpx;
}

.calendar-month {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 12rpx;
}

.weekday {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 8rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.calendar-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 12rpx;
  position: relative;
}

.calendar-day.other-month .day-text {
  color: var(--text-muted);
  opacity: 0.3;
}

.calendar-day.today {
  background: rgba(255, 107, 53, 0.15);
}

.calendar-day.today .day-text {
  color: var(--primary-color);
  font-weight: 700;
}

.calendar-day.checkin-day {
  background: rgba(0, 212, 170, 0.15);
}

.calendar-day.checkin-day .day-text {
  color: var(--success);
  font-weight: 600;
}

.calendar-day.today.checkin-day {
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.15), rgba(0, 212, 170, 0.15));
}

.day-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.checkin-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--success);
  position: absolute;
  bottom: 6rpx;
}

.calendar-summary {
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.summary-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
